    "@tiptap/extension-superscript": "^3.6.1",
    "@tiptap/extension-text-align": "^3.6.1",
    "@tiptap/extensions": "^3.6.1",
    "@tiptap/starter-kit": "^3.6.1",
    "@tiptap/vue-3": "^3.6.1",
    "@unovis/ts": "^1.6.1",
    "@unovis/vue": "^1.6.1",
